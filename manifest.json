{
  "manifest_version": 3,
  "name": "AI Website Dev Annotator: AI Notes & Markdown Export",
  "version": "1.8.0",
  "description": "Annotate any website element with notes, then copy/export as clean Markdown for Cursor, Claude Code, Copilot, and other AI agents.",
  "permissions": ["storage", "scripting", "contextMenus", "notifications", "tabs", "alarms"],
  "host_permissions": ["<all_urls>"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Website Dev Annotator",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default":  "Alt+Shift+A",
        "mac":      "Alt+Shift+A",
        "windows":  "Alt+Shift+A",
        "linux":    "Alt+Shift+A",
        "chromeos": "Alt+Shift+A"
      },
      "description": "Open AI Website Dev Annotator"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
